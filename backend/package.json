{
  "name": "beyond-classroom-api",
  "version": "1.0.0",
  "description": "Beyond Classroom REST API - Express + PostgreSQL",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:init": "psql $DATABASE_URL < src/db/schema.sql",
    "db:seed": "psql $DATABASE_URL < src/db/seed.sql"
  },
  "dependencies": {
    "express": "^5.1.0",
    "pg": "^8.13.0",
    "bcrypt": "^5.1.1",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/pg": "^8.11.0",
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/nodemailer": "^6.4.0",
    "@types/cors": "^2.8.0",
    "typescript": "~5.9.2",
    "nodemon": "^3.1.0",
    "ts-node": "^10.9.0"
  }
}
